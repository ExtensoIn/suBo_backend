/gradlew text eol=lf
*.bat text eol=crlf
*.jar binary

# Anything executed inside a container or by bash must stay LF. On Windows a
# CRLF checkout makes the shell fail to parse the file (`\r: command not
# found`), which is the same class of breakage that already affects /gradlew.
*.sh text eol=lf
Dockerfile text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Graph/build artifacts, never diffed.
*.obj binary
*.pbf binary
*.zip binary
