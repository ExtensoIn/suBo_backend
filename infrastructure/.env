# Local development only. Do not reuse these credentials anywhere real.

POSTGRES_DB=subo
POSTGRES_USER=root
POSTGRES_PASSWORD=pass123

# --- Optional overrides (defaults shown) -----------------------------------

# Published ports. APP_PORT binds 0.0.0.0 so the Expo app on a phone can
# reach it over the LAN.
# APP_PORT=8080
# OTP_PORT=8081

# Heap for every OTP invocation, including the graph builds. Raise if
# --buildStreet runs out of memory on a larger OSM extract.
#
# Measured: BUILDING the graph needs the 4g default, but merely SERVING it does
# not — at 1200m OTP serves the full Bolivia graph in ~1.49 GB RSS (vs 2.78 GB
# at 4g) with identical routing results.runs 1200m for that
# reason; keep 4g locally so the bootstrap builds still work.
# OTP_MAX_HEAP=4g

# The app container runs as this uid/gid so the GTFS export can write into the
# bind-mounted otp/data/. Set these if `id -u` is not 1000.
# APP_UID=1000
# APP_GID=1000

# Apple Silicon: postgis/postgis is amd64-only. Uncomment for a native arm64
# build (see README "Windows / macOS notes").
# POSTGIS_IMAGE=imresamu/postgis:18-3.6
